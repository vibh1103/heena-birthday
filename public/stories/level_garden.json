    "intro": {
      "id": "intro",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "happy",
          "text": "Heena, welcome to the Memory Garden. The fog is heavy now, but our most cherished memories are trapped inside these 4 crystals."
        },
        {
          "character": "heena",
          "emotion": "curious",
          "text": "It feels so dreamy and quiet... like walking through clouds."
        },
        {
          "character": "firefly",
          "emotion": "excited",
          "text": "Gather the 4 memory crystals. As you unlock each memory, the fog will clear, the music will soften, and the sunrise will begin."
        }
      ]
    },
    "fireflyHint": {
      "id": "fireflyHint",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "neutral",
          "text": "Search near the floating paths. Each crystal holds a beautiful moment of our lives together: Wedding, Baby, Trip, and Anniversary."
        }
      ]
    },
    "portalReady": {
      "id": "portalReady",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "excited",
          "text": "How beautiful... The fog is gone, the sun has risen, and the portal to the Birthday Castle is open. Step through when you are ready!"
        }
      ]
    },
