    "intro": {
      "id": "intro",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "happy",
          "text": "Welcome to the Wizard School, Heena! Here, magic isn't just coding—it's actual wizardry. Look at the floating candles and moving portraits!"
        },
        {
          "character": "heena",
          "emotion": "curious",
          "text": "Oh wow, are those candles floating? And I just saw a flying owl pass by! This is incredible!"
        },
        {
          "character": "firefly",
          "emotion": "excited",
          "text": "Indeed! But the spell door is locked. Gather the 6 glowing mana crystals around the room so we can brew our stabilizing potion!"
        }
      ]
    },
    "fireflyHint": {
      "id": "fireflyHint",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "neutral",
          "text": "Look around the spell libraries and potion desks. The mana crystals shine with a deep purple wizard glow!"
        }
      ]
    },
    "portalReady": {
      "id": "portalReady",
      "autoSave": true,
      "lines": [
        {
          "character": "firefly",
          "emotion": "excited",
          "text": "Excellent! The potion is mixed, the spell door traced open, and the portal to the Developer Dungeon is active. Proceed when you are ready!"
        }
      ]
    },
