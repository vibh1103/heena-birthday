        {
          "character": "firefly",
          "emotion": "happy",
          "text": "Bzzzt... Entering the Developer Dungeon. Watch your step, there are compiler errors everywhere!"
        },
        {
          "character": "heena",
          "emotion": "curious",
          "text": "Wow, this looks like a retro gaming terminal. What's the mission?"
        },
        {
          "character": "firefly",
          "emotion": "excited",
          "text": "We need to run npm run birthday! Gather 6 green binary crystals to solve the compilation errors and unlock the Memory Garden."
        }
